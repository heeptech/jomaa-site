<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="<%= settings.heroSubtitle %>">
    <title><%= title %> | <%= settings.siteName %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <% if (!isDashboard) { %>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/">
          <% if (settings.logoUrl) { %>
            <img class="brand-logo" src="<%= settings.logoUrl %>" alt="<%= settings.siteName %>">
          <% } else { %>
            <span class="brand-mark">ج</span>
          <% } %>
          <span><%= settings.siteName %></span>
        </a>
        <button class="nav-toggle" type="button" aria-label="فتح القائمة" aria-expanded="false">☰</button>
        <nav class="main-nav" aria-label="القائمة الرئيسية">
          <% settings.menu.forEach((item) => { %>
            <a class="<%= currentPath === item.href ? 'active' : '' %>" href="<%= item.href %>"><%= item.label %></a>
          <% }) %>
        </nav>
      </div>
    </header>
    <% } %>
    <main>
