<article class="article-card">
  <div class="article-meta">
    <time datetime="<%= article.publishedAt || article.createdAt %>">
      <%= new Date(article.publishedAt || article.createdAt).toLocaleDateString("ar-SY", { year: "numeric", month: "long", day: "numeric" }) %>
    </time>
    <span><%= article.author %></span>
  </div>
  <h3><a href="/articles/<%= article.slug || article.id %>"><%= article.title %></a></h3>
  <p><%= article.excerpt %></p>
  <a class="text-link" href="/articles/<%= article.slug || article.id %>">قراءة المقال</a>
</article>
