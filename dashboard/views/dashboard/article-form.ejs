<%- include("../partials/head") %>

<section class="dashboard-shell">
  <div class="container dashboard-layout">
    <aside class="dashboard-sidebar">
      <h1>لوحة التحكم</h1>
      <a href="/dashboard">المقالات</a>
      <a href="/dashboard/settings">إعدادات الموقع</a>
      <a href="/">عرض الموقع</a>
    </aside>
    <section class="dashboard-content">
      <div class="dashboard-topline">
        <div>
          <p class="eyebrow">تحرير المقال</p>
          <h2><%= article ? "تعديل مقال" : "مقال جديد" %></h2>
        </div>
      </div>

      <form class="editor-form" action="<%= article ? `/dashboard/articles/${article.id}` : '/dashboard/articles' %>" method="post" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          عنوان المقال
          <input type="text" name="title" value="<%= article ? article.title : '' %>" required>
        </label>
        <label>
          ملخص قصير
          <textarea name="excerpt" rows="3" maxlength="280" required><%= article ? article.excerpt : '' %></textarea>
        </label>
        <div class="form-grid">
          <label>
            الكاتب
            <input type="text" name="author" value="<%= article ? article.author : settings.authorName %>">
          </label>
          <label>
            الحالة
            <select name="status">
              <option value="published" <%= !article || article.status === "published" ? "selected" : "" %>>منشور</option>
              <option value="draft" <%= article && article.status === "draft" ? "selected" : "" %>>مسودة</option>
            </select>
          </label>
          <label>
            التصنيف
            <select name="category">
              <option value="">بدون تصنيف</option>
              <% categories.forEach((cat) => { %>
                <option value="<%= cat %>" <%= article && article.category === cat ? "selected" : "" %>><%= cat %></option>
              <% }) %>
            </select>
          </label>
        </div>
        <div class="field-block">
          <div class="form-grid">
            <label>
              الصورة الرئيسية للمقال
              <input type="file" name="coverImage" accept="image/*">
              <small>تظهر في صفحة المقالات وداخل المقال، مع قياس ثابت يحافظ على التصميم.</small>
            </label>
            <label>
              رابط الصورة الرئيسية
              <input type="text" name="coverImageUrl" value="<%= article && article.coverImage ? article.coverImage : '' %>" placeholder="/uploads/image.png أو https://...">
              <small>يمكن تركه فارغاً إذا رفعت صورة من الجهاز.</small>
            </label>
          </div>
          <% if (article && article.coverImage) { %>
            <div class="logo-preview">
              <span>الصورة الرئيسية الحالية</span>
              <img src="<%= article.coverImage %>" alt="الصورة الرئيسية الحالية">
            </div>
          <% } %>
          <label>
            صورة داخل النص
            <input type="file" name="inlineImage" accept="image/*">
            <small>عند الحفظ ستضاف الصورة داخل نص المقال، ويمكن نقل سطر الصورة لأي مكان داخل النص لاحقاً.</small>
          </label>
        </div>
        <label>
          نص المقال
          <textarea class="body-editor" name="body" rows="18" required><%= article ? article.body : '' %></textarea>
        </label>
        <div class="form-actions">
          <button class="button primary" type="submit">حفظ</button>
          <a class="button ghost" href="/dashboard">إلغاء</a>
        </div>
      </form>
    </section>
  </div>
</section>

<%- include("../partials/footer") %>
