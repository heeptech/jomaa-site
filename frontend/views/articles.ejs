<%- include("partials/head") %>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">الأرشيف</p>
    <h1>جميع المقالات</h1>
    <form class="search-form" action="/articles" method="get">
      <% if (category) { %>
        <input type="hidden" name="category" value="<%= category %>">
      <% } %>
      <input type="search" name="q" value="<%= query %>" placeholder="ابحث في العنوان أو النص أو الكاتب" aria-label="البحث في المقالات">
      <button class="button primary" type="submit">بحث</button>
    </form>
    <% if (categories && categories.length) { %>
      <div class="category-filter" aria-label="تصنيفات المقالات">
        <a class="<%= !category ? 'active' : '' %>" href="/articles<%= query ? `?q=${encodeURIComponent(query)}` : '' %>">الكل</a>
        <% categories.forEach((cat) => { %>
          <a class="<%= category === cat ? 'active' : '' %>" href="/articles?category=<%= encodeURIComponent(cat) %><%= query ? `&q=${encodeURIComponent(query)}` : '' %>"><%= cat %></a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="container results-line">
    <p><%= articles.length %> نتيجة<%= query ? ` عن "${query}"` : "" %><%= category ? ` - ${category}` : "" %></p>
    <% if (query || category) { %>
      <a class="text-link" href="/articles">مسح البحث</a>
    <% } %>
  </div>

  <% if (articles.length) { %>
    <div class="container category-sections">
      <% categorySections.forEach((section) => { %>
        <section class="category-section">
          <div class="category-section-head">
            <p class="eyebrow">تصنيف</p>
            <h2><%= section.name %></h2>
            <span><%= section.articles.length %> مقال</span>
          </div>
          <div class="cards-grid">
            <% section.articles.forEach((article) => { %>
              <%- include("partials/article-card", { article }) %>
            <% }) %>
          </div>
        </section>
      <% }) %>
    </div>
  <% } else { %>
    <div class="container">
      <div class="empty-state">
        <h2>لا توجد مقالات مطابقة</h2>
        <p>جرّب كلمات بحث أخرى أو عد إلى جميع المقالات.</p>
      </div>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
